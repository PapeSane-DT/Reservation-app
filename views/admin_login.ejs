<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Connexion Admin</title>
    <style>
        body { font-family: Arial, sans-serif; margin: 0; height: 100vh; display: flex; align-items: center; justify-content: center; background: #f4f4f4; }
        form { background: white; padding: 30px; border-radius: 8px; width: 320px; box-shadow: 0 2px 6px rgba(0,0,0,0.1); }
        h1 { font-size: 20px; margin-top: 0; color: #2c3e50; }
        label { display: block; margin-top: 12px; font-weight: bold; font-size: 14px; }
        input { width: 100%; padding: 8px; margin-top: 5px; box-sizing: border-box; }
        button { margin-top: 18px; width: 100%; padding: 10px; background: #2c3e50; color: white; border: none; border-radius: 4px; cursor: pointer; }
        .erreur { color: #e74c3c; font-size: 14px; margin-top: 10px; }
    </style>
</head>
<body>
    <form action="/admin/login" method="POST">
        <h1>Connexion administrateur</h1>
        <% if (erreur) { %>
            <p class="erreur"><%= erreur %></p>
        <% } %>
        <label>Email</label>
        <input type="email" name="email" required>
        <label>Mot de passe</label>
        <input type="password" name="password" required>
        <button type="submit">Se connecter</button>
    </form>
</body>
</html>